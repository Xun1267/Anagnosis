# AI API配置
# OpenAI API密钥
VITE_OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API基础URL (可选，用于代理或自定义端点)
VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# 默认AI模型
VITE_DEFAULT_AI_MODEL=gpt-3.5-turbo

# 应用配置
# 应用环境 (development, production)
VITE_APP_ENV=development

# 应用标题
VITE_APP_TITLE=Anagnosis

# 应用版本
VITE_APP_VERSION=1.0.0

# 文件上传配置
# 最大文件大小 (MB)
VITE_MAX_FILE_SIZE=50

# 支持的文件格式
VITE_SUPPORTED_FORMATS=epub,pdf,txt

# 存储配置
# 本地存储前缀
VITE_STORAGE_PREFIX=anagnosis_

# 数据库名称 (IndexedDB)
VITE_DB_NAME=AnagnosisDB

# 数据库版本
VITE_DB_VERSION=1

# 调试配置
# 启用调试模式
VITE_DEBUG=false

# 启用性能监控
VITE_PERFORMANCE_MONITORING=false

# API请求超时时间 (毫秒)
VITE_API_TIMEOUT=30000

# 重试次数
VITE_API_RETRY_COUNT=3